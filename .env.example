# Example env — copy to .env and fill in. Never commit real secrets.
#   cp .env.example .env
#
# Production deploy:
#   docker compose -f docker-compose.prod.yml --env-file .env up --build -d

# --- Ports (host bindings) ---
BACKEND_PORT=8000
FRONTEND_PORT=3000

# --- Frontend public URLs (baked into Next.js at build time) ---
# Use https:// / wss:// when behind a reverse proxy or Cloudflare tunnel.
NEXT_PUBLIC_API_URL=http://localhost:8000
NEXT_PUBLIC_WS_URL=ws://localhost:8000

# --- CORS (must include the browser origin that serves the UI) ---
# JSON array or comma-separated list
P4NT3XIA_CORS_ORIGINS=["http://localhost:3000","http://127.0.0.1:3000"]

# --- Auth (Phase 4) — enabled for production ---
P4NT3XIA_AUTH_ENABLED=true
# Generate: openssl rand -base64 48
P4NT3XIA_JWT_SECRET=change-me-to-a-long-random-string
P4NT3XIA_BOOTSTRAP_ADMIN_USER=admin
# Generate: openssl rand -base64 24
P4NT3XIA_BOOTSTRAP_ADMIN_PASSWORD=changeme-long-password
# Optional
# P4NT3XIA_BOOTSTRAP_ADMIN_EMAIL=admin@example.com

# --- Database ---
# Default (leave empty): SQLite at /app/data/p4nt3xia.db inside the backend volume.
# For Postgres (compose --profile postgres), set both:
# POSTGRES_USER=p4nt3xia
# POSTGRES_PASSWORD=change-me-strong-db-password
# POSTGRES_DB=p4nt3xia
# P4NT3XIA_DATABASE_URL=postgresql+psycopg2://p4nt3xia:change-me-strong-db-password@postgres:5432/p4nt3xia
P4NT3XIA_DATABASE_URL=

# --- Optional tool path overrides (prod images set sensible defaults) ---
# P4NT3XIA_FFUF_WORDLIST=/app/tools/wordlists/common.txt
# P4NT3XIA_HYDRA_WORDLIST=/app/tools/wordlists/passwords.txt
# P4NT3XIA_SSRFMAP_PATH=/usr/local/bin/ssrfmap
# P4NT3XIA_JWT_TOOL_PATH=/usr/local/bin/jwt_tool
# P4NT3XIA_FRIDA_PATH=frida
