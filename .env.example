# Example env — copy to .env and fill in. Never commit real secrets.
# cp .env.example .env

# Auth (Phase 4) — leave false for single-user local
P4NT3XIA_AUTH_ENABLED=false
P4NT3XIA_JWT_SECRET=change-me-to-a-long-random-string
# P4NT3XIA_BOOTSTRAP_ADMIN_USER=admin
# P4NT3XIA_BOOTSTRAP_ADMIN_PASSWORD=changeme-long-password

# Optional Postgres (default is SQLite under backend/data/)
# P4NT3XIA_DATABASE_URL=postgresql+psycopg2://p4nt3xia:p4nt3xia@localhost:5432/p4nt3xia

# CORS (JSON array or comma-separated)
# P4NT3XIA_CORS_ORIGINS=["http://localhost:3000"]

# Frontend public URLs (for tunnels / remote access)
# NEXT_PUBLIC_API_URL=http://localhost:8000
# NEXT_PUBLIC_WS_URL=ws://localhost:8000
